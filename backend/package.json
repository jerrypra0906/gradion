{
  "name": "gradion-backend",
  "version": "1.0.0",
  "description": "Gradion Backend API — ABA, AI summaries, and CMS",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "start:prod": "NODE_ENV=production node dist/index.js",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "prisma:seed": "tsx prisma/seed.ts",
    "prisma:seed:prod": "node dist/prisma/seed.js",
    "seed:cms": "tsx scripts/seed-cms-content.ts",
    "create:cms": "tsx scripts/create-cms-from-pages.ts",
    "create:admin": "tsx scripts/create-admin.ts",
    "test": "vitest",
    "test:coverage": "vitest --coverage"
  },
  "keywords": [
    "autism",
    "progress-tracker",
    "therapy",
    "api"
  ],
  "author": "Gradion",
  "license": "ISC",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.100.1",
    "@aws-sdk/client-s3": "^3.1057.0",
    "@fastify/cors": "^9.0.1",
    "@fastify/helmet": "^11.1.1",
    "@fastify/jwt": "^10.1.0",
    "@fastify/multipart": "^8.0.0",
    "@fastify/rate-limit": "^9.1.0",
    "@fastify/static": "^6.12.0",
    "@google/generative-ai": "^0.24.1",
    "@prisma/adapter-pg": "7.8.0",
    "@prisma/client": "7.8.0",
    "@supabase/supabase-js": "^2.106.2",
    "@types/pg": "^8.20.0",
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.3.1",
    "fastify": "^4.25.2",
    "google-auth-library": "^9.2.0",
    "jsonwebtoken": "^9.0.3",
    "midtrans-node": "^1.1.5",
    "openai": "^4.20.1",
    "pg": "^8.21.0",
    "pino": "^8.17.2",
    "pino-pretty": "^10.3.1",
    "prisma": "7.8.0",
    "resend": "^4.0.0",
    "sharp": "^0.34.5",
    "zod": "^3.22.4",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^20.10.6",
    "@typescript-eslint/eslint-plugin": "^6.17.0",
    "@typescript-eslint/parser": "^6.17.0",
    "axios": "^1.13.2",
    "eslint": "^8.56.0",
    "prettier": "^3.8.3",
    "tsx": "^4.22.3",
    "typescript": "^5.3.3",
    "vitest": "^4.1.7"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "overrides": {
    "jws": "^4.0.0",
    "fast-jwt": "^6.2.4"
  }
}
