NODE_ENV=development
PORT=3000
HOST=0.0.0.0
API_VERSION=v1

# URLs
FRONTEND_URL=http://localhost:5050
API_URL=http://localhost:5001
PUBLIC_API_URL=http://localhost:5001/api

# Database
# Gradion (recommended): dedicated Postgres — see docker-compose.gradion.yml (host port 5434 by default)
DATABASE_URL=postgresql://gradion_user:change-this-strong-password@localhost:5434/gradion?schema=public
# LangkahKecil legacy local DB (if you still use the old stack on port 5433):
# DATABASE_URL=postgresql://langkahkecil_user:change-this-strong-password@localhost:5433/langkahkecil?schema=public
DB_POOL_MIN=2
DB_POOL_MAX=10
DB_SSL_REQUIRED=false

# Auth
JWT_SECRET=change-this-in-production-12345678901234567890
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=change-this-refresh-secret-12345678901234567890
JWT_REFRESH_EXPIRES_IN=30d
BCRYPT_ROUNDS=12
SESSION_SECRET=change-this-session-secret-12345678901234567890

# Email — Resend (recommended) or SMTP (Gmail / Google Workspace)
# Leave RESEND_API_KEY empty until you have a real key; do not use placeholder values in production.
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@gradion.id
RESEND_FROM_NAME=Gradion
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM_EMAIL=
EMAIL_VERIFICATION_TOKEN_EXPIRATION_HOURS=24
EMAIL_VERIFICATION_RESEND_INTERVAL_MINUTES=10

# AI — Gemini is primary (TD Gradion). OpenAI is optional fallback.
ANTHROPIC_API_KEY=sk-ant-your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-sonnet-4-6
AI_VIDEO_MIN_TOKEN_CHARGE=3500
VIDEO_FIDELITY_MAX_FILE_MB=100
ENABLE_VIDEO_FIDELITY=true

AI_TOKEN_LIMIT_FREE_TRIAL=2000              # Free trial token limit (2-week trial pool)
FREE_TRIAL_WEEKS=2                          # New users get this many weeks of AI trial access
AI_TOKEN_LIMIT_BASIC=10000                  # Basic plan token limit
AI_TOKEN_LIMIT_PREMIUM=30000                # Premium plan token limit
AI_TOKEN_LIMIT_THERAPIST=50000              # Therapist plan token limit
AI_RATE_LIMIT_PER_MINUTE=5                  # Max AI calls per minute per user
AI_RATE_LIMIT_PER_DAY=100                   # Max AI calls per day per user
AI_MAX_PROMPT_LENGTH=1000                   # Max prompt length in characters
AI_MONTHLY_SPEND_LIMIT=100                  # Hard limit for monthly AI spend ($)

# Google OAuth
GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your-google-oauth-client-secret

# CORS
CORS_ORIGIN=http://localhost:5050
CORS_CREDENTIALS=true

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
AUTH_LOGIN_MAX_ATTEMPTS=10
AUTH_LOGIN_WINDOW_MS=900000

# Registration abuse protection
REGISTRATION_MAX_ATTEMPTS_PER_IP=5
REGISTRATION_WINDOW_MINUTES=60

# Payment — Midtrans (use sandbox keys for staging; see docs/STAGING_MIDTRANS.md)
MIDTRANS_SERVER_KEY=
MIDTRANS_CLIENT_KEY=
MIDTRANS_IS_PRODUCTION=false
MIDTRANS_WEBHOOK_SECRET=
MIDTRANS_FEE_PERCENTAGE=2.5

# Object storage — prefer R2 on Cloudflare/AWS deploy; Supabase is also supported.
# R2 (recommended for gradion.id on Cloudflare):
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET_NAME=gradion-uploads
# R2_PUBLIC_URL=https://cdn.gradion.id
# Supabase Storage (alternative):
# SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=
# SUPABASE_STORAGE_BUCKET=uploads

# Feature flags
ENABLE_AI_FEATURES=true
ENABLE_FILE_UPLOAD=false
ENABLE_ANALYTICS=true
ENABLE_CMS=true
