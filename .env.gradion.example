# Copy to .env.gradion and adjust, then:
#   docker compose -f docker-compose.gradion.yml --env-file .env.gradion up -d
#
# Postgres-only compose (docker-compose.gradion.yml) defaults to port 5435 so it
# does not conflict with the full stack (docker-compose.yml → Postgres on 5434).

POSTGRES_PORT_EXTERNAL=5435
POSTGRES_DB=gradion
POSTGRES_USER=gradion_user
POSTGRES_PASSWORD=change-this-strong-password
