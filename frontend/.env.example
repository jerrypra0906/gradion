# ============================================
# Gradion Frontend - Environment Variables
# ============================================
# Production-ready configuration
# Copy this file to .env.local (Next.js) or .env and fill in actual values
# NEVER commit .env files to version control

# ============================================
# Application Configuration
# ============================================
NODE_ENV=production
NEXT_PUBLIC_APP_NAME=Gradion
NEXT_PUBLIC_APP_VERSION=1.0.0

# ============================================
# API Configuration
# ============================================
# Backend API URL (must be accessible from browser)
NEXT_PUBLIC_API_URL=http://localhost:5001/api
NEXT_PUBLIC_GOOGLE_CLIENT_ID=716619312677-upn6u3mi723ridd90qugdhhubc026jod.apps.googleusercontent.com
# API version
NEXT_PUBLIC_API_VERSION=v1

# ============================================
# Application URLs
# ============================================
# Public frontend URL
# Site URL for SEO and metadata (used in sitemap, Open Graph, etc.)
NEXT_PUBLIC_SITE_URL=https://gradion.org
NEXT_PUBLIC_APP_URL=https://your-domain.com
# Landing page URL
NEXT_PUBLIC_LANDING_URL=https://your-domain.com

# ============================================
# Authentication
# ============================================
# JWT token storage key
NEXT_PUBLIC_TOKEN_KEY=gradion_token
NEXT_PUBLIC_REFRESH_TOKEN_KEY=gradion_refresh_token

# Session storage type (localStorage or sessionStorage)
NEXT_PUBLIC_STORAGE_TYPE=localStorage

# ============================================
# Payment Gateway (Client-side keys)
# ============================================
# Xendit Public Key (safe to expose)
NEXT_PUBLIC_XENDIT_PUBLIC_KEY=xnd_public_development_your-xendit-public-key

# Midtrans (sandbox for staging — see docs/STAGING_MIDTRANS.md)
NEXT_PUBLIC_MIDTRANS_CLIENT_KEY=SB-Mid-client-xxxxxxxx
NEXT_PUBLIC_MIDTRANS_IS_PRODUCTION=false

# ============================================
# Cloud Storage (Public URLs)
# ============================================
# Cloudflare R2 Public URL
NEXT_PUBLIC_STORAGE_URL=https://your-bucket.r2.cloudflarestorage.com

# Alternative: Supabase Storage Public URL
# NEXT_PUBLIC_STORAGE_URL=https://[PROJECT-REF].supabase.co/storage/v1/object/public

# ============================================
# Feature Flags (Client-side)
# ============================================
NEXT_PUBLIC_ENABLE_AI_FEATURES=true
NEXT_PUBLIC_ENABLE_FILE_UPLOAD=false
NEXT_PUBLIC_ENABLE_ANALYTICS=true
NEXT_PUBLIC_ENABLE_CMS=true

# ============================================
# Analytics & Tracking
# ============================================
# Google Analytics (optional)
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Sentry (client-side DSN)
NEXT_PUBLIC_SENTRY_DSN=your-sentry-dsn

# ============================================
# Subscription Plans (Display)
# ============================================
# Free Plan
NEXT_PUBLIC_PLAN_FREE_NAME=Free
NEXT_PUBLIC_PLAN_FREE_PRICE=0
NEXT_PUBLIC_PLAN_FREE_QUOTA=30
NEXT_PUBLIC_PLAN_FREE_AI_ACCESS=false

# Pro Plan
NEXT_PUBLIC_PLAN_PRO_NAME=Pro
NEXT_PUBLIC_PLAN_PRO_PRICE=79000
NEXT_PUBLIC_PLAN_PRO_QUOTA=300
NEXT_PUBLIC_PLAN_PRO_AI_ACCESS=true

# Premium Plan
NEXT_PUBLIC_PLAN_PREMIUM_NAME=Premium
NEXT_PUBLIC_PLAN_PREMIUM_PRICE=149000
NEXT_PUBLIC_PLAN_PREMIUM_QUOTA=1000
NEXT_PUBLIC_PLAN_PREMIUM_AI_ACCESS=true

# Trial Information
NEXT_PUBLIC_TRIAL_DURATION_DAYS=14
NEXT_PUBLIC_TRIAL_AI_SUMMARIES=50

# ============================================
# UI/UX Configuration
# ============================================
# Banner rotation interval (milliseconds)
NEXT_PUBLIC_BANNER_ROTATION_INTERVAL=3000
# Banner auto-hide delay (milliseconds)
NEXT_PUBLIC_BANNER_AUTO_HIDE_DELAY=10000
# Maximum number of banners to display
NEXT_PUBLIC_BANNER_MAX_COUNT=3

# ============================================
# CMS Configuration
# ============================================
# CMS API endpoint
NEXT_PUBLIC_CMS_API_URL=https://api.your-domain.com/api/cms

# ============================================
# Error Handling
# ============================================
# Show detailed errors in development
NEXT_PUBLIC_SHOW_ERROR_DETAILS=false

# ============================================
# Performance
# ============================================
# Enable service worker/PWA
NEXT_PUBLIC_ENABLE_PWA=true
# Cache version
NEXT_PUBLIC_CACHE_VERSION=1.0.0

# ============================================
# Social & Marketing
# ============================================
# Social media links (optional)
NEXT_PUBLIC_FACEBOOK_URL=
NEXT_PUBLIC_TWITTER_URL=
NEXT_PUBLIC_INSTAGRAM_URL=
NEXT_PUBLIC_LINKEDIN_URL=

# Support email
NEXT_PUBLIC_SUPPORT_EMAIL=support@your-domain.com

# ============================================
# Development/Testing (Optional)
# ============================================
# Only use in development/testing environments
# NEXT_PUBLIC_MOCK_API=false
# NEXT_PUBLIC_ENABLE_DEBUG_MODE=false

